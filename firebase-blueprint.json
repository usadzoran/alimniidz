{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "auth_id": { "type": "string", "description": "Firebase Auth ID" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "account_status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "profile_image": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["auth_id", "email", "role"]
    },
    "Post": {
      "title": "Post",
      "description": "News feed post",
      "type": "object",
      "properties": {
        "author_id": { "type": "string" },
        "author_name": { "type": "string" },
        "author_image": { "type": "string" },
        "content": { "type": "string" },
        "image_url": { "type": "string" },
        "likes_count": { "type": "integer" },
        "comments_count": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["author_id", "content", "created_at"]
    },
    "LiveClass": {
      "title": "Live Class",
      "description": "Live class session",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacher_id": { "type": "string" },
        "subject": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["upcoming", "live", "ended"] },
        "max_students": { "type": "integer" },
        "current_students": { "type": "integer" }
      },
      "required": ["title", "teacher_id", "status"]
    },
    "LessonFile": {
      "title": "Lesson File",
      "description": "Educational file",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "file_url": { "type": "string" },
        "uploaded_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "file_url"]
    },
    "ExplainVideo": {
      "title": "Explain Video",
      "description": "Educational video",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "video_url": { "type": "string" },
        "thumbnail_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "video_url"]
    },
    "Message": {
      "title": "Message",
      "description": "Private message",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["sender_id", "receiver_id", "content"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "plan": { "type": "string" },
        "status": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "plan"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/posts/{postId}": { "schema": "Post", "description": "Feed posts" },
    "/live_classes/{classId}": { "schema": "LiveClass", "description": "Live sessions" },
    "/lesson_files/{fileId}": { "schema": "LessonFile", "description": "Lesson files" },
    "/explain_videos/{videoId}": { "schema": "ExplainVideo", "description": "Educational videos" },
    "/messages/{messageId}": { "schema": "Message", "description": "Private messages" },
    "/subscriptions/{subId}": { "schema": "Subscription", "description": "User subscriptions" }
  }
}
